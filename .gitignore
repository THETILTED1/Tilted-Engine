# CMake/Ninja build trees (build/ = clang, build-gcc/ = gcc)
build/
build-gcc/

# Per-developer CMake preset overrides (CMakePresets.json itself is committed)
CMakeUserPresets.json

# clangd's on-disk index / cache
.cache/

# GCC module cache (only relevant to a future g++ build)
gcm.cache/

# Local design notes and scratch probes (not part of the engine)
reports/

# Editor / IDE settings
.vscode/

