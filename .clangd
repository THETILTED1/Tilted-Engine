# Per-file flags come from build/compile_commands.json (regenerate: cmake --preset clang).
CompileFlags:
  CompilationDatabase: build
---
# Bitboard.inl is #included into Tilted.Bitboard.cppm's purview, not compiled
# alone, so standalone it looks all-undefined. Give it C++ flags but suppress the
# false diagnostics; real errors surface in Tilted.Bitboard.cppm and the build.
If:
  PathMatch: .*\.inl
CompileFlags:
  Add: [-xc++, -std=c++23, -stdlib=libc++]
Diagnostics:
  Suppress: "*"
